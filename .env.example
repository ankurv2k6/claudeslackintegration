# Slack-Claude Integration Environment Configuration
# Copy this file to ~/.claude/slack_integration/.env and fill in your values

# ============================================================================
# Slack Configuration (Required)
# ============================================================================

# Bot token - starts with xoxb-
# Get this from: Slack App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token for Socket Mode - starts with xapp-
# Get this from: Slack App > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token

# Channel ID where Claude sessions will be posted
# Find this by right-clicking channel > Copy Link > extract ID starting with C
SLACK_CHANNEL_ID=C0123456789

# ============================================================================
# Security (Optional - auto-generated if not set)
# ============================================================================

# 64-character hex string for daemon authentication
# If not set, a secure random value will be generated on startup
# DAEMON_SECRET=your-64-char-hex-string

# ============================================================================
# Transport (Optional)
# ============================================================================

# IPC transport mode: 'unix' (default, more secure) or 'tcp'
TRANSPORT_MODE=unix

# TCP port if using tcp transport mode (default: 3847)
DAEMON_PORT=3847

# ============================================================================
# Authorization (Optional)
# ============================================================================

# Comma-separated list of Slack user IDs allowed to interact
# Leave empty or omit to allow all users
# AUTHORIZED_USERS=U0123456789,U9876543210

# ============================================================================
# Logging (Optional)
# ============================================================================

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
