{
  "name": "slack-claude-integration",
  "version": "0.1.0",
  "description": "Bidirectional Slack-Claude Code integration daemon",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ hooks/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "slack",
    "claude",
    "ai",
    "integration"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@slack/bolt": "3.17.1",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "p-queue": "8.0.1",
    "pino": "^9.3.2",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/pino": "^7.0.4",
    "@types/proper-lockfile": "^4.1.4",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^8.57.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.5"
  }
}
